generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Employee {
  employeeId         String         @id @default(cuid()) @map("employee_id")
  fullName           String         @map("full_name")
  emailAddress       String         @unique @map("email_address")
  assignedRole       EmployeeRole   @default(Developer) @map("assigned_role")
  assignedDepartment String         @map("assigned_department")
  appraisalState     AppraisalState @default(Pristine) @map("appraisal_state")
  privateAdminNotes  String?        @map("private_admin_notes")
  baseSalary         Decimal        @default(0) @map("base_salary") @db.Decimal(12, 2)
  allowances         Decimal        @default(0) @db.Decimal(12, 2)
  deductions         Decimal        @default(0) @db.Decimal(12, 2)
  isActive           Boolean        @default(true) @map("is_active")
  joinedAt           DateTime       @default(now()) @map("joined_at")
  managerId          String?        @map("manager_id")
  teamId             String?        @map("team_id")
  password           String
  username           String         @unique
  attendance         Attendance[]
  manager            Employee?      @relation("ManagerSubordinates", fields: [managerId], references: [employeeId])
  subordinates       Employee[]     @relation("ManagerSubordinates")
  team               Team?          @relation(fields: [teamId], references: [teamId])

  @@map("employees")
}

model Team {
  teamId            String     @id @default(cuid()) @map("team_id")
  teamName          String     @unique @map("team_name")
  projectTitle      String     @map("project_title")
  projectSummary    String?    @map("project_summary")
  milestoneDeadline DateTime   @map("milestone_deadline")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  employees         Employee[]

  @@map("teams")
}

model Attendance {
  attendanceId       BigInt           @id @default(autoincrement()) @map("attendance_id")
  employeeId         String           @map("employee_id")
  calendarDate       DateTime         @map("calendar_date") @db.Date
  shiftStatus        AttendanceStatus @default(Working) @map("shift_status")
  clockInTimestamp   DateTime?        @map("clock_in_timestamp") @db.Time(6)
  clockOutTimestamp  DateTime?        @map("clock_out_timestamp") @db.Time(6)
  totalHoursComputed Decimal          @default(8.00) @map("total_hours_computed") @db.Decimal(4, 2)
  employee           Employee         @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@unique([employeeId, calendarDate], name: "unique_employee_date_entry")
  @@index([employeeId, calendarDate], map: "idx_attendance_composite")
  @@map("attendance")
}

enum EmployeeRole {
  SuperAdmin
  Manager
  Developer
  Marketing
  CustomStaff
}

enum AppraisalState {
  Pristine
  AppraisalConsideration
  PerformanceWarning
}

enum AttendanceStatus {
  Working
  OnLeave
  Absent
}
